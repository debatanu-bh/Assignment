# shosho IoT Test Automation Configuration
# Copy this file to .env and update values for your environment:
#   cp .env.example .env

# Cloud configuration
CLOUD_BASE_URL=https://automation.shosho.com

# Device configuration (local IP of the test device)
DEVICE_BASE_URL=http://192.168.0.2

# Credentials
IENSO_USERNAME=test_user
IENSO_PASSWORD=test_pass

# Test configuration
RETRY_COUNT=3
RETRY_DELAY=1
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO